---
interface Props {
  id: string;
  label: string;
  title: string;
}
const { id, label, title } = Astro.props;
---

<section id={id} class="border-b border-line/50">
  <div class="mx-auto max-w-5xl px-6 py-20 md:py-24">
    <div class="reveal">
      <p
        class="mb-2 font-mono text-xs uppercase tracking-[0.2em] text-spark-500"
      >
        {label}
      </p>
      <h2
        class="font-display text-2xl font-bold tracking-tight text-mist-100 sm:text-3xl"
      >
        {title}
      </h2>
    </div>
    <div class="mt-10">
      <slot />
    </div>
  </div>
</section>
