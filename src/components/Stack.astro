---
import Section from "./Section.astro";

const current = [
  "TypeScript",
  "Node.js (NestJS)",
  "Next.js",
  "PostgreSQL",
  "Row-Level Security",
  "Prisma",
  "Python",
  "Git",
  "Zod",
  "TanStack Query",
  "Power BI",
];

const learning = ["Docker", "CI/CD (GitHub Actions)", "FastAPI", "pytest", "Inglés técnico"];
---

<Section id="stack" label="Stack" title="Con qué trabajo">
  <div class="grid gap-8 md:grid-cols-2">
    <div class="reveal">
      <p class="mb-4 text-sm font-medium text-mist-200">Uso hoy</p>
      <div class="flex flex-wrap gap-2">
        {
          current.map((t) => (
            <span class="rounded-lg border border-line bg-ink-900 px-3 py-1.5 text-sm text-mist-300">
              {t}
            </span>
          ))
        }
      </div>
    </div>
    <div class="reveal">
      <p class="mb-4 text-sm font-medium text-mist-200">Incorporando ahora</p>
      <div class="flex flex-wrap gap-2">
        {
          learning.map((t) => (
            <span class="rounded-lg border border-dashed border-spark-500/40 bg-spark-500/5 px-3 py-1.5 text-sm text-spark-400">
              {t}
            </span>
          ))
        }
      </div>
    </div>
  </div>
</Section>
