---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import Hero from "../components/Hero.astro";
import About from "../components/About.astro";
import Projects from "../components/Projects.astro";
import Stack from "../components/Stack.astro";
import Seeking from "../components/Seeking.astro";
import Contact from "../components/Contact.astro";
---

<Layout>
  <Nav />
  <div id="fullpage">
    <Hero />
    <About />
    <Projects />
    <Stack />
    <Seeking />
    <Contact />
  </div>
</Layout>

<script>
  // Full-page scroll SOLO en desktop con mouse. Un movimiento chico de rueda
  // desliza (con animación) a la sección siguiente; un gesto = un salto.
  // En mobile/touch queda deshabilitado → scroll normal.
  const mq = window.matchMedia("(min-width: 1024px) and (pointer: fine)");
  const fp = document.getElementById("fullpage");
  const panels = fp
    ? (Array.from(fp.children).filter(
        (el) => el.tagName === "SECTION" || el.tagName === "FOOTER",
      ) as HTMLElement[])
    : [];

  let animating = false;
  let cooldown: number | undefined;

  const lightboxOpen = () =>
    !!document.querySelector<HTMLDialogElement>("[data-lightbox]")?.open;

  const isTypingTarget = (t: EventTarget | null) =>
    t instanceof HTMLElement &&
    ["INPUT", "TEXTAREA", "SELECT"].includes(t.tagName);

  // Índice de la sección actual calculado EN VIVO desde el scroll (no de una
  // variable que se pueda desincronizar): la sección cuyo rango contiene el
  // centro de la ventana.
  function currentIndex(): number {
    const mid = window.scrollY + window.innerHeight / 2;
    for (let i = 0; i < panels.length; i++) {
      const top = panels[i].offsetTop;
      if (mid >= top && mid < top + panels[i].offsetHeight) return i;
    }
    return Math.max(
      0,
      Math.min(panels.length - 1, Math.round(window.scrollY / window.innerHeight)),
    );
  }

  // Duración del deslizamiento entre secciones (ms). Subir = más lento.
  const SLIDE_MS = 500;
  let rafId = 0;

  // Anima el scroll cuadro por cuadro (no depende de scroll-behavior del CSS
  // ni de scrollIntoView, que en algunos equipos/con "reducir movimiento" no
  // animan). Escribe scrollTop directo, que siempre es instantáneo por frame.
  function animateScrollTo(targetY: number, duration = SLIDE_MS) {
    cancelAnimationFrame(rafId);
    const startY = window.scrollY;
    const dist = targetY - startY;
    if (Math.abs(dist) < 1) return;
    const startT = performance.now();
    // easeInOutQuad
    const ease = (t: number) =>
      t < 0.5 ? 2 * t * t : 1 - Math.pow(-2 * t + 2, 2) / 2;
    const step = (now: number) => {
      const t = Math.min(1, (now - startT) / duration);
      window.scrollTo(0, Math.round(startY + dist * ease(t)));
      if (t < 1) rafId = requestAnimationFrame(step);
    };
    rafId = requestAnimationFrame(step);
  }

  function goTo(i: number) {
    const clamped = Math.max(0, Math.min(panels.length - 1, i));
    animating = true;
    animateScrollTo(panels[clamped].offsetTop);
    window.clearTimeout(cooldown);
    // Cooldown: bloquea nuevos saltos mientras dura la animación, para que
    // un solo gesto (o el impulso del touchpad) no encadene varios.
    cooldown = window.setTimeout(() => {
      animating = false;
    }, SLIDE_MS + 60);
  }

  function onWheel(e: WheelEvent) {
    if (!mq.matches || lightboxOpen()) return; // scroll nativo (mobile/touch)
    if (animating) {
      e.preventDefault();
      return;
    }
    const dir = e.deltaY > 0 ? 1 : e.deltaY < 0 ? -1 : 0;
    if (dir === 0) return;
    const i = currentIndex();
    const panel = panels[i];
    if (!panel) return;
    const top = panel.offsetTop;
    const bottom = top + panel.offsetHeight;
    const viewTop = window.scrollY;
    const viewBottom = viewTop + window.innerHeight;
    // Si la sección es más alta que la ventana, primero se scrollea su
    // contenido; recién al llegar al borde se salta a la siguiente.
    if (dir > 0 && viewBottom < bottom - 2) return;
    if (dir < 0 && viewTop > top + 2) return;
    e.preventDefault();
    goTo(i + dir);
  }

  function onKey(e: KeyboardEvent) {
    if (!mq.matches || lightboxOpen() || isTypingTarget(e.target)) return;
    const i = currentIndex();
    if (e.key === "ArrowDown" || e.key === "PageDown") {
      e.preventDefault();
      goTo(i + 1);
    } else if (e.key === "ArrowUp" || e.key === "PageUp") {
      e.preventDefault();
      goTo(i - 1);
    } else if (e.key === "Home") {
      e.preventDefault();
      goTo(0);
    } else if (e.key === "End") {
      e.preventDefault();
      goTo(panels.length - 1);
    }
  }

  // Marca de estado (no gatea la lógica — esa se evalúa en vivo con mq.matches
  // en cada gesto — solo deja un hook por si el CSS lo necesita).
  const syncActive = () =>
    document.documentElement.classList.toggle("fp-active", mq.matches);

  window.addEventListener("wheel", onWheel, { passive: false });
  window.addEventListener("keydown", onKey);
  syncActive();
  mq.addEventListener("change", syncActive);

  // Links internos (menú, CTAs, "hablemos"): mismo deslizamiento animado.
  // En desktop full-page van al tope exacto de la sección; en mobile se
  // descuenta el alto del header fijo para no tapar el título.
  document.querySelectorAll<HTMLAnchorElement>('a[href^="#"]').forEach((a) => {
    a.addEventListener("click", (e) => {
      const href = a.getAttribute("href") ?? "";
      const el = href.length > 1 ? document.getElementById(href.slice(1)) : null;
      if (!el) return;
      e.preventDefault();
      const headerH =
        document.querySelector("header")?.getBoundingClientRect().height ?? 0;
      const y = mq.matches ? el.offsetTop : Math.max(0, el.offsetTop - headerH);
      animating = true;
      animateScrollTo(y);
      window.clearTimeout(cooldown);
      cooldown = window.setTimeout(() => {
        animating = false;
      }, SLIDE_MS + 60);
      history.replaceState(null, "", href);
    });
  });
</script>
